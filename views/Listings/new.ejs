<%layout("/layouts/boilerplate.ejs")-%>
<body>
    <h3>Create new listing</h3>
    <form method="post" action="/listings">
        <input name="title" placeholder="Enter the title" type="text">
        <br>      <br>
        <textarea name="description" placeholder="Enter the description"></textarea>
        <br>      <br>
        <input type="text" name="image" placeholder="Enter the image url">
        <br>      <br>
        <input type ="number" name="price" placeholder="Enter the price">
        <br>      <br>
        <input type ="text" name="location" placeholder="Enter the location">
        <br>      <br>
        <input type ="text" name="country" placeholder="Enter the country">
        <button>Submit</button>
    </form>
</body>
